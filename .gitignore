# Dependencies
node_modules/
__pycache__/
*.pyc
*.pyo

# Environment
.env
.env.local
.env.*
!.env.example

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/

# Temp / backup files
*.bak
*.tmp
*.temp
AGENT_TEST.tmp

# Claude Code runtime artifacts
.claude/agents/__test_write.tmp
.claude/worktrees/

# Binary / generated documents (not source)
*.docx
*.xlsx
*.pptx
*.pdf

# Plugin zip (rebuilt by scripts/build_plugin.py — not source)
sdlc-automation.plugin
claude-sdlc-pipeline.plugin

# Pipeline runtime outputs (regenerated on every run)
# Ignore contents of each output dir but keep the dir itself via .gitkeep
outputs/transcripts/*
outputs/requirements/*
outputs/documents/*
outputs/planning/*
outputs/jira/*
outputs/architecture/*
outputs/code/*
outputs/qa/*
outputs/deployment/*
outputs/security/*
outputs/compliance/*
outputs/cost/*
outputs/feedback/*
outputs/analytics/*
outputs/PROJECT_COMPLETE_SUMMARY.md
outputs/EXECUTIVE_DASHBOARD.md
outputs/pipeline_final.json

# Keep directory structure — .gitkeep files are always tracked
!outputs/**/.gitkeep
