  "database_schema": {
    "strategy": {
      "primary_keys": "UUIDs (v4) to prevent sequential enumeration",
      "timestamps": "created_at and updated_at on all tables",
      "soft_deletes": "deleted_at column on critical tables for SOC2 data retention",
      "audit": "Append-only audit_logs table with 2-year retention",
      "normalization": "3NF for transactional data; denormalized views for dashboards",
      "multi_tenancy": "Row-level security (RLS) with client_id filtering for client data isolation"
    },
    "tables": [
      {
        "name": "users",
        "description": "All platform users including internal staff and client users",
        "columns": [
          { "name": "id", "type": "UUID", "constraints": "PRIMARY KEY DEFAULT gen_random_uuid()" },
          { "name": "email", "type": "VARCHAR(255)", "constraints": "UNIQUE NOT NULL" },
          { "name": "password_hash", "type": "VARCHAR(255)", "constraints": "NOT NULL" },
          { "name": "first_name", "type": "VARCHAR(100)", "constraints": "NOT NULL" },
          { "name": "last_name", "type": "VARCHAR(100)", "constraints": "NOT NULL" },
          { "name": "is_active", "type": "BOOLEAN", "constraints": "DEFAULT true" },
          { "name": "totp_secret", "type": "VARCHAR(255)", "constraints": "NULLABLE" },
          { "name": "client_id", "type": "UUID", "constraints": "NULLABLE REFERENCES clients(id)" },
          { "name": "last_login_at", "type": "TIMESTAMPTZ", "constraints": "NULLABLE" },
          { "name": "created_at", "type": "TIMESTAMPTZ", "constraints": "DEFAULT NOW()" },
          { "name": "updated_at", "type": "TIMESTAMPTZ", "constraints": "DEFAULT NOW()" },
          { "name": "deleted_at", "type": "TIMESTAMPTZ", "constraints": "NULLABLE" }
        ],
        "indexes": [
          { "name": "idx_users_email", "columns": ["email"], "unique": true },
          { "name": "idx_users_client_id", "columns": ["client_id"] }
        ]
      },
      {
        "name": "roles",
        "description": "RBAC role definitions (Admin, Executive, PM, Team Lead, Team Member, Finance Manager, Client User)",
        "columns": [
          { "name": "id", "type": "UUID", "constraints": "PRIMARY KEY DEFAULT gen_random_uuid()" },
          { "name": "name", "type": "VARCHAR(50)", "constraints": "UNIQUE NOT NULL" },
          { "name": "display_name", "type": "VARCHAR(100)", "constraints": "NOT NULL" },
          { "name": "description", "type": "TEXT", "constraints": "NULLABLE" },
          { "name": "permissions", "type": "JSONB", "constraints": "NOT NULL DEFAULT '{}'" },
          { "name": "is_system", "type": "BOOLEAN", "constraints": "DEFAULT false" },
          { "name": "created_at", "type": "TIMESTAMPTZ", "constraints": "DEFAULT NOW()" },
          { "name": "updated_at", "type": "TIMESTAMPTZ", "constraints": "DEFAULT NOW()" }
        ],
        "indexes": [
          { "name": "idx_roles_name", "columns": ["name"], "unique": true }
        ]
      },
      {
        "name": "user_roles",
        "description": "Many-to-many mapping of users to roles",
        "columns": [
          { "name": "id", "type": "UUID", "constraints": "PRIMARY KEY DEFAULT gen_random_uuid()" },
          { "name": "user_id", "type": "UUID", "constraints": "NOT NULL REFERENCES users(id) ON DELETE CASCADE" },
          { "name": "role_id", "type": "UUID", "constraints": "NOT NULL REFERENCES roles(id) ON DELETE CASCADE" },
          { "name": "assigned_by", "type": "UUID", "constraints": "REFERENCES users(id)" },
          { "name": "created_at", "type": "TIMESTAMPTZ", "constraints": "DEFAULT NOW()" }
        ],
        "indexes": [
          { "name": "idx_user_roles_user_id", "columns": ["user_id"] },
          { "name": "idx_user_roles_unique", "columns": ["user_id", "role_id"], "unique": true }
        ]
      },
      {
        "name": "clients",
        "description": "Client organizations that have projects on the platform",
        "columns": [
          { "name": "id", "type": "UUID", "constraints": "PRIMARY KEY DEFAULT gen_random_uuid()" },
          { "name": "name", "type": "VARCHAR(255)", "constraints": "NOT NULL" },
          { "name": "industry", "type": "VARCHAR(100)", "constraints": "NULLABLE" },
          { "name": "primary_contact_email", "type": "VARCHAR(255)", "constraints": "NULLABLE" },
          { "name": "billing_address", "type": "JSONB", "constraints": "NULLABLE" },
          { "name": "is_active", "type": "BOOLEAN", "constraints": "DEFAULT true" },
          { "name": "created_at", "type": "TIMESTAMPTZ", "constraints": "DEFAULT NOW()" },
          { "name": "updated_at", "type": "TIMESTAMPTZ", "constraints": "DEFAULT NOW()" }
        ],
        "indexes": [
          { "name": "idx_clients_name", "columns": ["name"] },
          { "name": "idx_clients_is_active", "columns": ["is_active"] }
        ]
      },
      {
        "name": "projects",
        "description": "Client projects with budget, timeline, and status tracking",
        "columns": [
          { "name": "id", "type": "UUID", "constraints": "PRIMARY KEY DEFAULT gen_random_uuid()" },
          { "name": "client_id", "type": "UUID", "constraints": "NOT NULL REFERENCES clients(id)" },
          { "name": "name", "type": "VARCHAR(255)", "constraints": "NOT NULL" },
          { "name": "description", "type": "TEXT", "constraints": "NULLABLE" },
          { "name": "status", "type": "VARCHAR(30)", "constraints": "NOT NULL DEFAULT 'active' CHECK (status IN ('draft','active','on_hold','completed','archived'))" },
          { "name": "start_date", "type": "DATE", "constraints": "NOT NULL" },
          { "name": "deadline", "type": "DATE", "constraints": "NOT NULL" },
          { "name": "budget", "type": "DECIMAL(12,2)", "constraints": "NULLABLE" },
          { "name": "created_by", "type": "UUID", "constraints": "NOT NULL REFERENCES users(id)" },
          { "name": "created_at", "type": "TIMESTAMPTZ", "constraints": "DEFAULT NOW()" },
          { "name": "updated_at", "type": "TIMESTAMPTZ", "constraints": "DEFAULT NOW()" },
          { "name": "deleted_at", "type": "TIMESTAMPTZ", "constraints": "NULLABLE" }
        ],
        "indexes": [
          { "name": "idx_projects_client_id", "columns": ["client_id"] },
          { "name": "idx_projects_status", "columns": ["status"] }
        ]
      },
      {
        "name": "project_members",
