  "security_controls": [
    {
      "id": "SEC-001",
      "name": "JWT Authentication",
      "description": "Stateless JWT access tokens (RS256, 15-minute expiry) with Redis-backed refresh tokens (7-day TTL). Short-lived access tokens minimize exposure window; refresh tokens enable seamless session continuity with fast revocation on logout.",
      "implementation": "jsonwebtoken library with RS256 signing. Refresh tokens stored in Redis with TTL. Auth middleware validates JWT on every request.",
      "soc2_criteria": "CC6.1 - Logical Access Security"
    },
    {
      "id": "SEC-002",
      "name": "Role-Based Access Control (RBAC)",
      "description": "Seven predefined roles (Admin, Executive, PM, Team Lead, Team Member, Finance Manager, Client User) with granular permission matrix per resource and action. Enforced at middleware level on every API endpoint.",
      "implementation": "RBAC middleware checks user roles and permissions against endpoint requirements. Permissions stored in roles.permissions JSONB column.",
      "soc2_criteria": "CC6.3 - Role-Based Access"
    },
    {
      "id": "SEC-003",
      "name": "Two-Factor Authentication (2FA)",
      "description": "TOTP-based 2FA mandatory for all users via authenticator apps (Google Authenticator, Authy). SMS fallback available. Satisfies SOC2 MFA requirements.",
      "implementation": "speakeasy library for TOTP generation and verification. 2FA setup required on first login. Backup codes generated during setup.",
      "soc2_criteria": "CC6.1 - Multi-Factor Authentication"
    },
    {
      "id": "SEC-004",
      "name": "Encryption at Rest",
      "description": "AES-256 encryption for all data at rest: PostgreSQL (RDS encryption), S3 (SSE-S3/SSE-KMS), Redis (encryption at rest). Passwords hashed with bcrypt (cost factor 12).",
      "implementation": "AWS RDS encryption enabled. S3 bucket policy enforces SSE. Redis ElastiCache encryption at rest. bcrypt for password hashing.",
      "soc2_criteria": "CC6.7 - Encryption of Data at Rest"
    },
    {
      "id": "SEC-005",
      "name": "Encryption in Transit",
      "description": "TLS 1.2+ enforced for all data in transit. Nginx terminates TLS at the reverse proxy. Internal service communication within VPC uses encrypted channels.",
      "implementation": "AWS ACM certificates on ALB. Nginx configured with TLS 1.2+ minimum. HSTS headers enabled.",
      "soc2_criteria": "CC6.7 - Encryption of Data in Transit"
    },
    {
      "id": "SEC-006",
      "name": "Comprehensive Audit Logging",
      "description": "All CRUD operations, login/logout events, permission changes, and data exports logged to an immutable append-only audit_logs table with before/after values, IP address, and user agent. 2-year retention with S3 Object Lock (WORM) for archival.",
      "implementation": "Audit middleware intercepts all state-changing requests. Winston structured JSON logging. S3 Object Lock for immutable archival.",
      "soc2_criteria": "CC7.2 - System Monitoring, CC4.1 - Monitoring Activities"
    },
    {
      "id": "SEC-007",
      "name": "Rate Limiting",
      "description": "Rate limiting at Nginx reverse proxy level: 10 requests/minute on /api/auth endpoints to prevent brute force. Account lockout after 5 failed login attempts (15-minute cooldown). General API rate limiting of 100 requests/minute per user.",
      "implementation": "Nginx rate limiting module. Redis-backed counters for account lockout. express-rate-limit middleware as secondary defense.",
      "soc2_criteria": "CC6.1 - Protection Against Unauthorized Access"
    },
    {
      "id": "SEC-008",
      "name": "Input Validation and Injection Prevention",
      "description": "Server-side validation on all inputs using schema validation. Parameterized queries via Prisma ORM prevent SQL injection. Output encoding prevents XSS. CSRF tokens on state-changing requests. Content Security Policy headers enforced.",
      "implementation": "Joi/Zod schema validation middleware. Prisma parameterized queries. helmet.js for security headers. csurf for CSRF protection.",
      "soc2_criteria": "CC6.6 - Security Event Management"
    },
    {
      "id": "SEC-009",
      "name": "CORS Policy",
      "description": "Strict CORS whitelist allowing only the application frontend domain and approved integration callback URLs. Wildcard origins explicitly blocked. Credentials mode restricted.",
      "implementation": "Nginx CORS headers. Express cors middleware with strict origin whitelist. Preflight request handling.",
      "soc2_criteria": "CC6.1 - Logical Access Security"
    },
    {
      "id": "SEC-010",
      "name": "Client Data Isolation (Multi-Tenancy)",
      "description": "Row-level security (RLS) with mandatory client_id foreign key on all client-scoped tables. PostgreSQL RLS policies automatically filter queries by the authenticated user's client_id. Prevents cross-tenant data access.",
      "implementation": "PostgreSQL CREATE POLICY statements on client-scoped tables. Application-level client_id injection from JWT claims. Integration tests verify isolation.",
      "soc2_criteria": "CC6.3 - Data Segregation, CC3.1 - Confidentiality"
    }
  ],
